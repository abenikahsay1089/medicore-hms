# Database
POSTGRES_DB=medicore
POSTGRES_USER=medicore
POSTGRES_PASSWORD=medicore_secret
DATABASE_URL=jdbc:postgresql://localhost:5432/medicore

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# RabbitMQ
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=medicore
RABBITMQ_PASSWORD=medicore_secret

# JWT
JWT_SECRET=your-256-bit-secret-key-change-in-production-must-be-at-least-32-chars
JWT_ACCESS_EXPIRATION=900000
JWT_REFRESH_EXPIRATION=604800000

# AWS S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=medicore-files
AWS_REGION=us-east-1

# Email
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# App
APP_FRONTEND_URL=http://localhost:5173
APP_BACKEND_URL=http://localhost:8080
